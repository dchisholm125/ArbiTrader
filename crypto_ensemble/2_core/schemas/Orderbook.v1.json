{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core.schemas.Orderbook.v1",
  "type": "object",
  "required": ["ts","asset","venue","seq","checksum","l2"],
  "properties": {
    "ts": {"type":"string","format":"date-time"},
    "asset": {"type":"string"},
    "venue": {"type":"string"},
    "seq": {"type":"integer","minimum":0},
    "checksum": {"type":"string"},
    "l2": {
      "type":"array","minItems":1,
      "items": {
        "type":"object",
        "required":["px","qty","side"],
        "properties":{"px":{"type":"number"},"qty":{"type":"number"},"side":{"enum":["bid","ask"]}}
      }
    },
    "spread_bps":{"type":["number","null"]}
  }
}
